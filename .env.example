# Postgres (local via docker compose or managed RDS)
DATABASE_URL=postgres://sentinel:sentinel@localhost:5432/sentinel

# LLM provider: `ollama` (default, local, no API key) or `openai`
LLM_PROVIDER=ollama

# Ollama (default). Requires: `ollama pull llama3.1:8b && ollama pull nomic-embed-text`
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=llama3.1:8b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# OpenAI (only used when LLM_PROVIDER=openai; also change vector dim in init.sql to 1536)
OPENAI_API_KEY=sk-replace-me
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Chat API
CHAT_API_PORT=4000
CHAT_API_URL=http://localhost:4000
CHAT_API_SHARED_SECRET=change-me-in-prod
CHAT_RATE_LIMIT_PER_MIN=30

# Auth.js
AUTH_SECRET=generate-with-openssl-rand-base64-32
AUTH_URL=http://localhost:3000

# Sanity
NEXT_PUBLIC_SANITY_PROJECT_ID=your-project-id
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_READ_TOKEN=

# AWS (only needed for Lambda deploy)
AWS_REGION=us-west-2
AWS_LOG_GROUP=/sentinel/chat-api
S3_TRANSCRIPT_BUCKET=sentinel-portal-transcripts
